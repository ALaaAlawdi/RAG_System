OPENAI_API_KEY=your-openai-api-key-here

# OCR
DATALAB_API_KEY=your-datalab-api-key-here

# File storage
UPLOAD_MAX_BYTES=20971520
UPLOADS_DIR=uploads
OUTPUTS_DIR=outputs

# OCR provider: "cloud" (Datalab) or "local" (vLLM)
OCR_PROVIDER=cloud
OCR_CLOUD_URL=https://www.datalab.to/api/v1/marker
OCR_LOCAL_URL=http://localhost:8000/v1

# OCR marker parameters (all optional — defaults shown)
OCR_OUTPUT_FORMAT=markdown
OCR_LANGS=ar,en
OCR_SKIP_CACHE=false
OCR_TABLE_ROW_BBOXES=true
OCR_DISABLE_IMAGE_CAPTIONS=true
OCR_EXTRACT_LINKS=true
OCR_PAGINATE=false
OCR_KEEP_PAGE_HEADER=false
OCR_KEEP_PAGE_FOOTER=false
OCR_NEW_BLOCK_TYPES=false

# OCR polling
OCR_POLL_INTERVAL_SECONDS=3.0
OCR_MAX_POLL_ATTEMPTS=40
